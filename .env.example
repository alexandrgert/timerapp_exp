# Секреты портала для TaskTimer — скопируйте в .env в корне репозитория.
# Дополнительно: ~/.config/tasktimer/.env (Linux) или %APPDATA%\TaskTimer\.env (Windows).
# Входящий вебхук: Приложения → Разработчикам → Входящий вебхук
# Права вебхука: Задачи (task), CRM (crm), Пользователи (user).
BITRIX24_HOOK_URL=https://YOUR_PORTAL.bitrix24.ru/rest/1/YOUR_WEBHOOK_SECRET/
# Таймаут HTTP в секундах
BITRIX24_TIMEOUT=180

# Опционально: ключ VibeCode API для MCP (mcp-vibe-api)
# VIBE_API_KEY=vibe_api_your_key_here

# Опционально: синхронизация data.json по WebDAV (Nextcloud, Яндекс.Диск и др.)
# Настройки также доступны в UI: Настройки → WebDAV
# Вебхук Битрикс24 хранится отдельно в ~/.config/tasktimer/bitrix.json (не синхронизируется).
# WEBDAV_ENABLED=1
# WEBDAV_URL=https://cloud.example.com/remote.php/dav/files/username/
# WEBDAV_USERNAME=username
# WEBDAV_PASSWORD=secret
# WEBDAV_REMOTE_PATH=tasktimer/data.json
# TASKTIMER_TERMINAL_MODE=1   # не перехватывать SIGINT при отладке из терминала
# BITRIX24_BI_TOKEN=

# Опционально: BI-аналитика (чтение crm_deal, crm_lead, task — skill bitrix24-bi-connector)
# BITRIX24_PORTAL_URL=https://YOUR_PORTAL.bitrix24.ru
# BITRIX24_BI_TOKEN=
